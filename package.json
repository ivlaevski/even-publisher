{
  "name": "article-publisher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --strictPort",
    "build": "vite build && node scripts/bump-build.mjs",
    "preview": "vite preview --host 0.0.0.0 --strictPort",
    "qr": "evenhub qr --port 5173 --path /",
    "init:evenhub": "evenhub init --output app.json",
    "pack": "npm run build && evenhub pack app.json ./dist --output article-publisher.ehpk",
    "pack:check": "evenhub pack app.json ./dist --check"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.44.0",
    "@evenrealities/even_hub_sdk": "^0.0.10",
    "@evenrealities/evenhub-cli": "^0.1.13",
    "@google/generative-ai": "^0.24.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
